# =============================================================================
# Photonest 環境変数テンプレート（本番想定）
#   cp .env.example .env して値を設定する。.env は Git 管理外（.gitignore 済み）。
#   STG など別環境は .env.staging.example を参照。
# =============================================================================

# --- 環境識別 / Compose -------------------------------------------------------
# docker compose のプロジェクト名（コンテナ/ネットワークの接頭辞）。
# 環境ごとに変えることで本番と STG を同一ホストで共存できる。
COMPOSE_PROJECT_NAME=photonest
# アプリの実行モード（production / development）。
FLASK_ENV=production

# --- ホスト側のパス・ポート・ネットワーク（docker-compose.yml が参照）---------
# 永続データのホスト側ルート（db_data / data がこの下に作られる）。
HOST_DATA_ROOT=/volume1/docker/photonest
# Web 公開ポート（リバースプロキシからつなぐ）。bind は既定 127.0.0.1。
WEB_BIND_ADDR=127.0.0.1
WEB_HOST_PORT=8050
# DB 公開ポート（ホスト→コンテナ 3306）。
DB_HOST_PORT=3307
DB_CONTAINER_NAME=mariadb
# 利用する Docker イメージタグ。
WEB_IMAGE=photonest:latest
DB_IMAGE=photonest-db:latest
# 外部ネットワーク名とサブネット（環境ごとに分ける）。
DOCKER_NETWORK_NAME=photonest-dev
DOCKER_NETWORK_SUBNET=172.22.0.0/16

# --- ドメイン / URL -----------------------------------------------------------
# アプリが自分自身を参照する URL（ヘルスチェック・絶対URL生成等）。
API_BASE_URL=https://photonest.example.com
# CORS 許可オリジン（カンマ区切り）。フロントの配信ドメインを指定。
CORS_ALLOWED_ORIGINS=https://photonest.example.com

# --- Database ----------------------------------------------------------------
MARIADB_ROOT_PASSWORD=strong-mariadb-root-password-here
MARIADB_USER=web_user
MARIADB_PASSWORD=strong-mariadb-web_user-password-here
MARIADB_DATABASE=appdb

# --- Redis / Celery ----------------------------------------------------------
REDIS_PASSWORD=strong-redis-password-here
REDIS_URL=redis://:strong-redis-password-here@redis:6379/0
CELERY_BROKER_URL=redis://:strong-redis-password-here@redis:6379/0
CELERY_RESULT_BACKEND=redis://:strong-redis-password-here@redis:6379/0

# --- コンテナ実行ユーザー -----------------------------------------------------
PUID=1000
PGID=1000

# --- 画像・メディア配信（nginx / X-Accel-Redirect / CDN）----------------------
# 公開ポートは nginx コンテナが受け持ち、web(gunicorn) は内部のみ。外部リバース
# プロキシ／CDN は WEB_HOST_PORT（上記）へ接続する。
# メディア（サムネイル・オリジナル・動画）は nginx が X-Accel-Redirect で
# ディスクから直接配信する（Python を経由せず高速）。docker-compose では既定で
# 有効（MEDIA_ACCEL_REDIRECT_ENABLED=true）。無効化したい場合のみ false にする。
#   注意: 有効時に web へ直接アクセスすると壊れる。必ず nginx 経由で使う。
MEDIA_ACCEL_REDIRECT_ENABLED=true
# accel の内部ロケーションとメディアディレクトリは settings 既定
# （/media/{thumbs,playback,originals}、/app/data/media/*）を使うため通常は未指定でよい。
# CDN を使う場合はエッジのオリジンをこの nginx（WEB_HOST_PORT を公開するドメイン）へ向ける。
# CDN_ENABLED=true
# CDN_PROVIDER=cloudflare               # none / azure / cloudflare / generic
# CDN_CLOUDFLARE_API_TOKEN=<token>
# CDN_CLOUDFLARE_ZONE_ID=<zone-id>
# CDN_CLOUDFLARE_ORIGIN_HOSTNAME=photonest.example.com
# CDN_CACHE_TTL=3600

# --- 初期管理者（任意）-------------------------------------------------------
# 設定すると seed 時の初期管理者パスワードに使われる（未設定はフォールバック）。
# ADMIN_INITIAL_PASSWORD=change-me-strong

# --- Mail（パスワードリセット用、任意）---------------------------------------
# MAIL_PROVIDER=smtp
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USE_SSL=False
# MAIL_USERNAME=your-email@example.com
# MAIL_PASSWORD=your-app-password
# MAIL_DEFAULT_SENDER=your-email@example.com
