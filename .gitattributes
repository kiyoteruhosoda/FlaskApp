# Normalize line endings to LF in the repository
* text=auto eol=lf

# Force LF for source files
*.py    text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.ts    text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.sh    text eol=lf
*.sql   text eol=lf
*.rst   text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf
.env     text eol=lf
.env.example text eol=lf

# Binary files — no conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.otf   binary
*.zip   binary
*.gz    binary
*.tar   binary
*.db    binary
*.sqlite binary
*.pyc   binary
