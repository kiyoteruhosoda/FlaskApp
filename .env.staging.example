# =============================================================================
# Photonest STG（ステージング）環境テンプレート
#   cp .env.staging.example .env して STG ホスト/プロジェクトで使う。
#   本番と同一ホストでも、プロジェクト名・ポート・データルート・ネットワークを
#   分けることで共存できる。値（特に資格情報・ドメイン）は環境に合わせて変更する。
# =============================================================================

# --- 環境識別 / Compose -------------------------------------------------------
COMPOSE_PROJECT_NAME=photonest-stg
FLASK_ENV=production

# --- ホスト側のパス・ポート・ネットワーク（本番とずらす）---------------------
HOST_DATA_ROOT=/volume1/docker/photonest-stg
WEB_BIND_ADDR=127.0.0.1
WEB_HOST_PORT=8051
DB_HOST_PORT=3308
DB_CONTAINER_NAME=mariadb-stg
WEB_IMAGE=photonest:latest
DB_IMAGE=photonest-db:latest
DOCKER_NETWORK_NAME=photonest-stg
DOCKER_NETWORK_SUBNET=172.23.0.0/16

# --- ドメイン / URL（STG 用）-------------------------------------------------
API_BASE_URL=https://stg.photonest.example.com
CORS_ALLOWED_ORIGINS=https://stg.photonest.example.com

# --- Database（STG 専用の資格情報にする）------------------------------------
MARIADB_ROOT_PASSWORD=stg-mariadb-root-password-here
MARIADB_USER=web_user
MARIADB_PASSWORD=stg-mariadb-web_user-password-here
MARIADB_DATABASE=appdb

# --- Redis / Celery ----------------------------------------------------------
REDIS_PASSWORD=stg-redis-password-here
REDIS_URL=redis://:stg-redis-password-here@redis:6379/0
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# --- コンテナ実行ユーザー -----------------------------------------------------
PUID=1000
PGID=1000

# --- 初期管理者（任意）-------------------------------------------------------
# ADMIN_INITIAL_PASSWORD=change-me-strong
